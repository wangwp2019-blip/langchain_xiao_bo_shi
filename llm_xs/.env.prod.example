# 小博士生产/灰度环境变量模板（复制为 .env.prod 后填写，勿提交 Git）
# 用法: docker compose --env-file .env.prod -f docker-compose.yml -f docker-compose.prod.yml up -d

# ---------- 必填（docker-compose.prod.yml 会校验）----------
KIDS_API_KEYS=replace-with-strong-random-key
KIDS_INGEST_TOKEN=replace-with-ingest-token
KIDS_RETENTION_SWEEP_TOKEN=replace-with-cron-token
KIDS_CORS_ORIGINS=https://your-domain.example.com
KIDS_METRICS_TOKEN=replace-with-metrics-token
# 与认证服务共享的 JWT 密钥（backend 验证、auth 签发，必须一致，≥32 字节随机）
KIDS_JWT_SECRET=replace-with-32byte-random-jwt-secret

# ---------- 数据库密码（勿使用 kid/kid）----------
POSTGRES_PASSWORD=replace-postgres-password
MYSQL_PASSWORD=replace-mysql-password

# ---------- 认证服务（--profile auth 时必填）----------
LLM_XS_FRONTEND_URL=https://your-domain.example.com
AUTH_TOKEN_EXPIRE_MINUTES=720

# ---------- 成本护栏 ----------
# 每用户每日在线大模型调用上限（0=不限）
KIDS_LLM_DAILY_QUOTA_PER_USER=200

# ---------- 可选 ----------
GRAFANA_ADMIN_PASSWORD=replace-grafana-password
GRAFANA_ROOT_URL=https://your-domain.example.com/grafana
TLS_CERT_DIR=./deploy/certs
KIDS_LANGSMITH_PROJECT=kid-assistant-prod

# ---------- 告警通知（monitoring profile，二选一或同时配置）----------
# 钉钉/飞书/自建网关：接收 Prometheus 标准 JSON webhook
ALERTMANAGER_WEBHOOK_URL=
# Slack Incoming Webhook
ALERTMANAGER_SLACK_WEBHOOK=

# ---------- 流式 SSE ----------
# true=LLM 逐 token 推送；false=先算完再 12 字符分块（兼容旧客户端）
KIDS_CHAT_STREAM_NATIVE=true
